# ── Claude / Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── JIRA ────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# ── GitHub ──────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# ── Azure DevOps ────────────────────────────────────────────────────
AZDO_ORG_URL=https://dev.azure.com/your-org
AZDO_PROJECT=
AZDO_PAT=

# ── GitLab ──────────────────────────────────────────────────────────
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=

# ── Jenkins ─────────────────────────────────────────────────────────
JENKINS_BASE_URL=https://jenkins.example.com
JENKINS_USER=
JENKINS_API_TOKEN=

# ── Optimizer tuning ────────────────────────────────────────────────
# Where the local response cache lives
TOKENOPT_CACHE_DIR=.tokenopt_cache
# Model used for the main reasoning calls
TOKENOPT_MODEL=claude-opus-4-8
# Cheaper model used to pre-summarize large inputs
TOKENOPT_SUMMARY_MODEL=claude-haiku-4-5

# ── Optional local model (no cloud tokens) ──────────────────────────
# Abstractive summarization via a locally-running Ollama server. Leave blank
# to use the deterministic offline strategies only. To enable: install Ollama,
# run `ollama pull llama3.2`, then set the model name below.
TOKENOPT_LOCAL_MODEL=
TOKENOPT_LOCAL_MODEL_URL=http://localhost:11434
